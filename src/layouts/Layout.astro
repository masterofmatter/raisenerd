---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
}
const { title, description, canonical } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <!-- Google AdSense — swap ca-pub-XXXXXXXXXXXXXXXX once approved -->
  <!-- <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script> -->
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --indigo: #1e1b4b;
      --indigo-mid: #312e81;
      --green: #059669;
      --green-light: #10b981;
      --bg: #f8fafc;
      --card: #ffffff;
      --border: #e2e8f0;
      --text: #0f172a;
      --muted: #64748b;
      --radius: 10px;
    }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }
    a { color: var(--green); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* Nav */
    header {
      background: var(--indigo);
      padding: 0 1.5rem;
      position: sticky;
      top: 0;
      z-index: 100;
      box-shadow: 0 2px 8px rgba(0,0,0,0.25);
    }
    nav {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      gap: 1.5rem;
      height: 56px;
      flex-wrap: wrap;
    }
    .logo {
      font-size: 1.15rem;
      font-weight: 700;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      white-space: nowrap;
    }
    .logo span { color: var(--green-light); }
    nav ul {
      display: flex;
      list-style: none;
      gap: 0.1rem;
      flex-wrap: wrap;
    }
    nav ul a {
      color: rgba(255,255,255,0.75);
      font-size: 0.82rem;
      padding: 0.3rem 0.6rem;
      border-radius: 6px;
      transition: background 0.15s;
      white-space: nowrap;
    }
    nav ul a:hover { background: rgba(255,255,255,0.1); color: #fff; text-decoration: none; }
    .currency-select {
      margin-left: auto;
      background: rgba(255,255,255,0.1);
      border: 1px solid rgba(255,255,255,0.2);
      color: rgba(255,255,255,0.85);
      font-size: 0.82rem;
      padding: 0.25rem 0.5rem;
      border-radius: 5px;
      cursor: pointer;
      flex-shrink: 0;
    }
    .currency-select:focus { outline: none; border-color: var(--green-light); }
    .currency-select option { background: var(--indigo); color: #fff; }

    /* Layout */
    .page-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 2rem;
      align-items: start;
    }
    @media (max-width: 768px) {
      .page-wrap { grid-template-columns: 1fr; }
      .sidebar { display: none; }
    }
    main { min-width: 0; }

    /* Card */
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.75rem;
      margin-bottom: 1.5rem;
    }
    .card h1 { font-size: 1.6rem; color: var(--indigo); margin-bottom: 0.5rem; }
    .card h2 { font-size: 1.15rem; color: var(--indigo); margin-bottom: 1rem; }
    .card p { color: var(--muted); margin-bottom: 1rem; }

    /* Calculator form */
    .calc-form { display: flex; flex-direction: column; gap: 1rem; }
    .field label {
      display: block;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--indigo);
      margin-bottom: 0.4rem;
    }
    .field input, .field select {
      width: 100%;
      padding: 0.6rem 0.85rem;
      border: 1.5px solid var(--border);
      border-radius: 7px;
      font-size: 1rem;
      color: var(--text);
      background: #fff;
      transition: border-color 0.15s;
    }
    .field input:focus, .field select:focus {
      outline: none;
      border-color: var(--green);
    }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .field-row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; }
    @media (max-width: 480px) { .field-row, .field-row-3 { grid-template-columns: 1fr; } }
    .btn {
      background: var(--green);
      color: #fff;
      border: none;
      padding: 0.75rem 1.5rem;
      border-radius: 7px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
      align-self: flex-start;
    }
    .btn:hover { background: var(--green-light); }
    .btn-outline {
      background: transparent;
      color: var(--green);
      border: 1.5px solid var(--green);
    }
    .btn-outline:hover { background: var(--green); color: #fff; }

    /* Results */
    .results {
      display: none;
      margin-top: 1.25rem;
      padding: 1.25rem;
      background: #f0fdf4;
      border: 1.5px solid #6ee7b7;
      border-radius: var(--radius);
    }
    .results.show { display: block; }
    .results-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: 1rem;
      margin-top: 0.75rem;
    }
    .result-item { text-align: center; }
    .result-value {
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--indigo);
      display: block;
    }
    .result-label {
      font-size: 0.78rem;
      color: var(--muted);
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }
    .result-highlight .result-value { color: var(--green); }

    /* Ad slots */
    .ad-slot {
      background: var(--card);
      border: 1px dashed var(--border);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--muted);
      font-size: 0.8rem;
      margin-bottom: 1.5rem;
    }
    .ad-slot-banner { height: 90px; }
    .ad-slot-sidebar { height: 250px; margin-bottom: 1rem; }
    .ad-slot-sidebar-tall { height: 600px; }

    /* Sidebar */
    .sidebar { position: sticky; top: 72px; }
    .sidebar-links { list-style: none; }
    .sidebar-links li { border-bottom: 1px solid var(--border); }
    .sidebar-links a {
      display: block;
      padding: 0.65rem 0.5rem;
      font-size: 0.9rem;
      color: var(--text);
    }
    .sidebar-links a:hover { color: var(--green); text-decoration: none; }

    /* Formula box */
    .formula-box {
      background: #f0fdf4;
      border-left: 3px solid var(--green);
      padding: 0.85rem 1rem;
      border-radius: 0 6px 6px 0;
      font-family: monospace;
      font-size: 0.9rem;
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
    }

    /* FAQ */
    details {
      border-bottom: 1px solid var(--border);
      padding: 0.75rem 0;
    }
    details summary {
      cursor: pointer;
      font-weight: 600;
      font-size: 0.95rem;
      color: var(--indigo);
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    details summary::after { content: '+'; font-size: 1.2rem; color: var(--green); }
    details[open] summary::after { content: '−'; }
    details p { margin-top: 0.6rem; font-size: 0.9rem; color: var(--muted); }

    /* Bench table */
    .bench-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; margin-top: 0.75rem; }
    .bench-table th { background: var(--indigo); color: #fff; padding: 0.5rem 0.75rem; text-align: left; font-size: 0.8rem; }
    .bench-table td { padding: 0.5rem 0.75rem; border-bottom: 1px solid var(--border); color: var(--muted); }
    .bench-table tr:last-child td { border-bottom: none; }

    /* Footer */
    footer {
      background: var(--indigo);
      color: rgba(255,255,255,0.6);
      text-align: center;
      padding: 1.5rem;
      font-size: 0.82rem;
      margin-top: 2rem;
    }
    footer a { color: rgba(255,255,255,0.7); }
    footer .footer-links { display: flex; justify-content: center; gap: 1.25rem; margin-bottom: 0.75rem; flex-wrap: wrap; }
  </style>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="logo">🤓 Raise<span>Nerd</span></a>
      <ul>
        <li><a href="/pay-raise-calculator/">Pay Raise</a></li>
        <li><a href="/overtime-calculator/">Overtime</a></li>
        <li><a href="/salary-to-hourly-calculator/">Salary ↔ Hourly</a></li>
        <li><a href="/paycheck-calculator/">Paycheck</a></li>
        <li><a href="/cost-of-living-calculator/">Cost of Living</a></li>
      </ul>
      <select id="currency-select" class="currency-select" onchange="setCurrency(this.value)" aria-label="Currency">
        <option value="USD">$ USD</option>
        <option value="GBP">£ GBP</option>
        <option value="EUR">€ EUR</option>
        <option value="AUD">A$ AUD</option>
        <option value="CAD">C$ CAD</option>
        <option value="INR">₹ INR</option>
      </select>
    </nav>
  </header>

  <div class="page-wrap">
    <main>
      <slot />
    </main>
    <aside class="sidebar">
      <div class="ad-slot ad-slot-sidebar">Ad</div>
      <div class="card" style="padding:1rem;">
        <p style="font-size:0.8rem;font-weight:700;color:var(--indigo);margin-bottom:0.6rem;">ALL CALCULATORS</p>
        <ul class="sidebar-links">
          <li><a href="/pay-raise-calculator/">Pay Raise Calculator</a></li>
          <li><a href="/overtime-calculator/">Overtime Calculator</a></li>
          <li><a href="/salary-to-hourly-calculator/">Salary to Hourly</a></li>
          <li><a href="/paycheck-calculator/">Paycheck Calculator</a></li>
          <li><a href="/cost-of-living-calculator/">Cost of Living</a></li>
        </ul>
      </div>
      <div class="ad-slot ad-slot-sidebar-tall" style="margin-top:1rem;">Ad</div>
    </aside>
  </div>

  <script is:inline>
    window.__CURRENCIES = [
      { code: 'USD', locale: 'en-US', symbol: '$'  },
      { code: 'GBP', locale: 'en-GB', symbol: '£'  },
      { code: 'EUR', locale: 'de-DE', symbol: '€'  },
      { code: 'AUD', locale: 'en-AU', symbol: 'A$' },
      { code: 'CAD', locale: 'en-CA', symbol: 'C$' },
      { code: 'INR', locale: 'en-IN', symbol: '₹'  },
    ];
    function setCurrency(code) {
      localStorage.setItem('preferred_currency', code);
      window.__currency = window.__CURRENCIES.find(c => c.code === code) || window.__CURRENCIES[0];
      document.dispatchEvent(new Event('currencychange'));
    }
    (function initCurrency() {
      const saved = localStorage.getItem('preferred_currency') || 'USD';
      window.__currency = window.__CURRENCIES.find(c => c.code === saved) || window.__CURRENCIES[0];
      const sel = document.getElementById('currency-select');
      if (sel) sel.value = window.__currency.code;
    })();
  </script>
  <footer>
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/pay-raise-calculator/">Pay Raise</a>
      <a href="/overtime-calculator/">Overtime</a>
      <a href="/salary-to-hourly-calculator/">Salary ↔ Hourly</a>
      <a href="/paycheck-calculator/">Paycheck</a>
      <a href="/cost-of-living-calculator/">Cost of Living</a>
    </div>
    <p>© {new Date().getFullYear()} RaiseNerd.com — Free Salary & HR Calculators</p>
    <p style="margin-top:0.4rem;font-size:0.75rem;">Results are estimates for informational purposes. Tax calculations are approximations — consult a payroll professional for exact figures.</p>
  </footer>
</body>
</html>
