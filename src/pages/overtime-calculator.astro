---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Overtime Calculator — Free | RaiseNerd"
  description="Calculate overtime pay for time-and-a-half, double time, and total weekly pay. Works for hourly and salaried workers. Free, instant results."
>
  <div class="card">
    <h1>Overtime Calculator</h1>
    <p>Enter your hourly rate and hours worked to calculate regular pay, overtime pay, and total weekly earnings.</p>
  </div>


  <div class="card">
    <h2>Calculate Your Overtime Pay</h2>
    <div class="calc-form">
      <div class="field-row">
        <div class="field">
          <label for="hourly-rate">Hourly Rate ($)</label>
          <input type="number" id="hourly-rate" placeholder="e.g. 25.00" min="0" step="0.01" />
        </div>
        <div class="field">
          <label for="regular-hours">Regular Hours / Week</label>
          <input type="number" id="regular-hours" placeholder="e.g. 40" min="0" step="0.5" value="40" />
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="ot-hours">Overtime Hours (1.5×)</label>
          <input type="number" id="ot-hours" placeholder="e.g. 8" min="0" step="0.5" value="0" />
        </div>
        <div class="field">
          <label for="dt-hours">Double Time Hours (2×)</label>
          <input type="number" id="dt-hours" placeholder="e.g. 0" min="0" step="0.5" value="0" />
        </div>
      </div>
      <div class="field">
        <label for="ot-multiplier">Overtime Multiplier</label>
        <select id="ot-multiplier">
          <option value="1.5">1.5× — Time and a half (standard)</option>
          <option value="2">2× — Double time</option>
          <option value="1.25">1.25× — Some union agreements</option>
        </select>
      </div>
      <button class="btn" onclick="calculate()">Calculate Overtime</button>
    </div>

    <div class="results" id="results">
      <strong style="color:var(--text);">Weekly Pay Breakdown</strong>
      <div class="results-grid" style="margin-top:0.75rem;">
        <div class="result-item">
          <span class="result-value" id="regular-pay">—</span>
          <span class="result-label">Regular Pay</span>
        </div>
        <div class="result-item result-highlight">
          <span class="result-value" id="ot-pay">—</span>
          <span class="result-label">Overtime Pay</span>
        </div>
        <div class="result-item">
          <span class="result-value" id="dt-pay">—</span>
          <span class="result-label">Double Time Pay</span>
        </div>
        <div class="result-item result-highlight">
          <span class="result-value" id="total-pay">—</span>
          <span class="result-label">Total Weekly Pay</span>
        </div>
      </div>
      <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid #6ee7b7;">
        <div class="results-grid">
          <div class="result-item">
            <span class="result-value" id="ot-rate">—</span>
            <span class="result-label">Overtime Rate/hr</span>
          </div>
          <div class="result-item">
            <span class="result-value" id="annual-est">—</span>
            <span class="result-label">Annual Est. (52 wks)</span>
          </div>
        </div>
      </div>
    </div>
  </div>


  <div class="card">
    <h2>Overtime Pay Rules — US Federal &amp; State</h2>
    <p>Under the federal Fair Labor Standards Act (FLSA), overtime kicks in after 40 hours in a workweek at 1.5× your regular rate. A few states have stricter daily thresholds.</p>
    <table class="bench-table">
      <thead><tr><th>Jurisdiction</th><th>Overtime Threshold</th><th>OT Rate</th></tr></thead>
      <tbody>
        <tr><td>Federal (FLSA)</td><td>After 40 hrs/week</td><td>1.5×</td></tr>
        <tr><td>California</td><td>After 8 hrs/day or 40 hrs/week</td><td>1.5× (2× after 12 hrs/day or 8 hrs on 7th consecutive day)</td></tr>
        <tr><td>Nevada</td><td>After 8 hrs/day (if wage &lt; 1.5× min. wage) or 40 hrs/week</td><td>1.5×</td></tr>
        <tr><td>Alaska</td><td>After 8 hrs/day or 40 hrs/week</td><td>1.5×</td></tr>
        <tr><td>All other states</td><td>After 40 hrs/week</td><td>1.5×</td></tr>
      </tbody>
    </table>
    <p style="margin-top:0.75rem;font-size:0.85rem;">Most states follow the federal 40-hour weekly threshold. Always verify with your state's Department of Labor — rules vary by industry and exempt status.</p>
  </div>

  <div class="card">
    <h2>Frequently Asked Questions</h2>
    <details>
      <summary>How is overtime pay calculated?</summary>
      <p>Overtime pay = regular hourly rate × overtime multiplier × overtime hours. Under the FLSA, standard overtime is 1.5× (time and a half). Example: $25/hr regular × 1.5 × 5 overtime hours = $187.50 in overtime pay for the week. Your total weekly pay would be $25 × 40 regular hours + $187.50 = $1,187.50.</p>
    </details>
    <details>
      <summary>Do salaried employees get overtime?</summary>
      <p>It depends on your classification. Under the FLSA, salaried employees earning less than $684/week ($35,568/year) are generally entitled to overtime regardless of job duties. Above that threshold, executive, administrative, and professional employees are typically exempt. If you're misclassified, you can file a complaint with the US Department of Labor Wage and Hour Division.</p>
    </details>
    <details>
      <summary>Can my employer refuse to pay overtime?</summary>
      <p>No — if you are a non-exempt employee under the FLSA, your employer is legally required to pay overtime at 1.5× your regular rate for hours over 40 in a workweek. Employers cannot waive this requirement through an agreement or policy. If you're owed unpaid overtime, you can file a complaint at dol.gov or consult an employment attorney.</p>
    </details>
    <details>
      <summary>What is comp time instead of overtime pay?</summary>
      <p>Compensatory time off (comp time) in lieu of overtime pay is generally not allowed for private-sector employees under the FLSA — you must receive cash payment at 1.5×. Comp time is permitted for state and local government employees under specific conditions. Some employers offer voluntary comp time informally, but this doesn't satisfy your legal right to overtime pay.</p>
    </details>
  </div>
</Layout>

<script is:inline>
function fmt(n, d = 2) {
  const c = window.__currency || { locale: 'en-US', code: 'USD' };
  return new Intl.NumberFormat(c.locale, { style: 'currency', currency: c.code, minimumFractionDigits: d, maximumFractionDigits: d }).format(n);
}
function calculate() {
  const rate = parseFloat(document.getElementById('hourly-rate').value) || 0;
  const regHours = parseFloat(document.getElementById('regular-hours').value) || 0;
  const otHours = parseFloat(document.getElementById('ot-hours').value) || 0;
  const dtHours = parseFloat(document.getElementById('dt-hours').value) || 0;
  const otMult = parseFloat(document.getElementById('ot-multiplier').value) || 1.5;

  if (rate <= 0) { alert('Please enter your hourly rate.'); return; }

  const regularPay = rate * regHours;
  const otRate = rate * otMult;
  const otPay = otRate * otHours;
  const dtPay = rate * 2 * dtHours;
  const total = regularPay + otPay + dtPay;

  document.getElementById('regular-pay').textContent = fmt(regularPay);
  document.getElementById('ot-pay').textContent = fmt(otPay);
  document.getElementById('dt-pay').textContent = fmt(dtPay);
  document.getElementById('total-pay').textContent = fmt(total);
  document.getElementById('ot-rate').textContent = fmt(otRate) + '/hr';
  document.getElementById('annual-est').textContent = fmt(total * 52, 0);
  document.getElementById('results').classList.add('show');
}
document.addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
document.addEventListener('currencychange', () => { if (document.getElementById('results').classList.contains('show')) calculate(); });
</script>
