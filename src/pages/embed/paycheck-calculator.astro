---
import EmbedLayout from '../../layouts/EmbedLayout.astro';
---
<EmbedLayout
  title="Paycheck Calculator — RaiseNerd"
  fullUrl="https://raisenerd.com/paycheck-calculator/"
  fullLabel="Paycheck Calculator"
>
  <div class="card">
    <h2>Paycheck Calculator</h2>
    <p style="font-size:0.82rem;margin-bottom:0.85rem;">Estimate take-home pay after federal, state, and FICA taxes. Results are estimates.</p>
    <div class="calc-form">
      <div class="field-row">
        <div class="field">
          <label for="gross-income">Annual Gross Income ($)</label>
          <input type="number" id="gross-income" placeholder="e.g. 65000" min="0" step="100" />
        </div>
        <div class="field">
          <label for="filing-status">Filing Status</label>
          <select id="filing-status">
            <option value="single">Single</option>
            <option value="mfj">Married Filing Jointly</option>
          </select>
        </div>
      </div>
      <div class="field-row">
        <div class="field">
          <label for="state">State</label>
          <select id="state">
            <option value="AL">Alabama</option><option value="AK">Alaska (no tax)</option><option value="AZ">Arizona</option><option value="AR">Arkansas</option><option value="CA">California</option><option value="CO">Colorado</option><option value="CT">Connecticut</option><option value="DE">Delaware</option><option value="FL">Florida (no tax)</option><option value="GA">Georgia</option><option value="HI">Hawaii</option><option value="ID">Idaho</option><option value="IL">Illinois</option><option value="IN">Indiana</option><option value="IA">Iowa</option><option value="KS">Kansas</option><option value="KY">Kentucky</option><option value="LA">Louisiana</option><option value="ME">Maine</option><option value="MD">Maryland</option><option value="MA">Massachusetts</option><option value="MI">Michigan</option><option value="MN">Minnesota</option><option value="MS">Mississippi</option><option value="MO">Missouri</option><option value="MT">Montana</option><option value="NE">Nebraska</option><option value="NV">Nevada (no tax)</option><option value="NH">New Hampshire (no tax)</option><option value="NJ">New Jersey</option><option value="NM">New Mexico</option><option value="NY">New York</option><option value="NC">North Carolina</option><option value="ND">North Dakota</option><option value="OH">Ohio</option><option value="OK">Oklahoma</option><option value="OR">Oregon</option><option value="PA">Pennsylvania</option><option value="RI">Rhode Island</option><option value="SC">South Carolina</option><option value="SD">South Dakota (no tax)</option><option value="TN">Tennessee (no tax)</option><option value="TX" selected>Texas (no tax)</option><option value="UT">Utah</option><option value="VT">Vermont</option><option value="VA">Virginia</option><option value="WA">Washington (no tax)</option><option value="WV">West Virginia</option><option value="WI">Wisconsin</option><option value="WY">Wyoming (no tax)</option><option value="DC">Washington, DC</option>
          </select>
        </div>
        <div class="field">
          <label for="pay-freq">Pay Frequency</label>
          <select id="pay-freq">
            <option value="26">Biweekly (26/year)</option>
            <option value="24">Semi-monthly (24/year)</option>
            <option value="12">Monthly (12/year)</option>
            <option value="52">Weekly (52/year)</option>
          </select>
        </div>
      </div>
      <button class="btn" onclick="calculate()">Calculate Take-Home Pay</button>
    </div>
    <div class="results" id="results">
      <strong>Estimated Deductions (Annual)</strong>
      <div class="results-grid" style="margin-top:0.75rem;">
        <div class="result-item"><span class="result-value" id="fed-tax">—</span><span class="result-label">Federal Tax</span></div>
        <div class="result-item"><span class="result-value" id="state-tax">—</span><span class="result-label">State Tax</span></div>
        <div class="result-item"><span class="result-value" id="ss">—</span><span class="result-label">Social Security</span></div>
        <div class="result-item"><span class="result-value" id="medicare">—</span><span class="result-label">Medicare</span></div>
      </div>
      <div style="margin-top:1rem;padding-top:1rem;border-top:1px solid #fcd34d;">
        <div class="results-grid">
          <div class="result-item result-highlight"><span class="result-value" id="net-annual">—</span><span class="result-label">Annual Take-Home</span></div>
          <div class="result-item result-highlight"><span class="result-value" id="net-paycheck">—</span><span class="result-label">Per Paycheck</span></div>
          <div class="result-item"><span class="result-value" id="effective-rate">—</span><span class="result-label">Effective Tax Rate</span></div>
          <div class="result-item"><span class="result-value" id="marginal-rate">—</span><span class="result-label">Marginal Rate</span></div>
        </div>
      </div>
    </div>
  </div>
</EmbedLayout>

<script is:inline>
const FED = {
  single: { brackets: [{min:0,max:11925,rate:0.10},{min:11925,max:48475,rate:0.12},{min:48475,max:103350,rate:0.22},{min:103350,max:197300,rate:0.24},{min:197300,max:250525,rate:0.32},{min:250525,max:626350,rate:0.35},{min:626350,max:Infinity,rate:0.37}], stdDeduction:14600, medicareSurchargeThreshold:200000 },
  mfj: { brackets: [{min:0,max:23850,rate:0.10},{min:23850,max:96950,rate:0.12},{min:96950,max:206700,rate:0.22},{min:206700,max:394600,rate:0.24},{min:394600,max:501050,rate:0.32},{min:501050,max:751600,rate:0.35},{min:751600,max:Infinity,rate:0.37}], stdDeduction:29200, medicareSurchargeThreshold:250000 },
};
const SS_WAGE_BASE = 176100;
const STATE_RATES = {AL:0.050,AK:0,AZ:0.025,AR:0.044,CA:0.093,CO:0.044,CT:0.065,DE:0.066,FL:0,GA:0.055,HI:0.082,ID:0.058,IL:0.050,IN:0.031,IA:0.057,KS:0.057,KY:0.040,LA:0.043,ME:0.072,MD:0.058,MA:0.050,MI:0.043,MN:0.099,MS:0.047,MO:0.054,MT:0.068,NE:0.066,NV:0,NH:0,NJ:0.075,NM:0.059,NY:0.109,NC:0.048,ND:0.025,OH:0.040,OK:0.048,OR:0.099,PA:0.031,RI:0.060,SC:0.065,SD:0,TN:0,TX:0,UT:0.047,VT:0.088,VA:0.058,WA:0,WV:0.065,WI:0.077,WY:0,DC:0.090};
function calcBracketTax(taxable, brackets) {
  let tax = 0;
  for (const b of brackets) { if (taxable <= b.min) break; tax += (Math.min(taxable, b.max) - b.min) * b.rate; }
  return Math.max(0, tax);
}
function getMarginalRate(taxable, brackets) {
  let rate = brackets[0].rate;
  for (const b of brackets) { if (taxable > b.min) rate = b.rate; }
  return rate;
}
function fmt(n, d = 0) {
  const c = window.__currency || { locale: 'en-US', code: 'USD' };
  return new Intl.NumberFormat(c.locale, { style: 'currency', currency: c.code, minimumFractionDigits: d, maximumFractionDigits: d }).format(n);
}
function calculate() {
  const gross = parseFloat(document.getElementById('gross-income').value) || 0;
  const status = document.getElementById('filing-status').value;
  const state = document.getElementById('state').value;
  const freq = parseInt(document.getElementById('pay-freq').value) || 26;
  if (gross <= 0) { alert('Please enter your gross income.'); return; }
  const fedData = FED[status];
  const fedTaxable = Math.max(0, gross - fedData.stdDeduction);
  const fedTax = calcBracketTax(fedTaxable, fedData.brackets);
  const marginalRate = getMarginalRate(fedTaxable, fedData.brackets);
  const ss = Math.min(gross, SS_WAGE_BASE) * 0.062;
  const medicare = gross * 0.0145 + Math.max(0, gross - fedData.medicareSurchargeThreshold) * 0.009;
  const stateRate = STATE_RATES[state] || 0;
  const stateTax = Math.max(0, gross - fedData.stdDeduction) * stateRate;
  const totalDeductions = fedTax + stateTax + ss + medicare;
  const netAnnual = gross - totalDeductions;
  const effectiveRate = (totalDeductions / gross) * 100;
  document.getElementById('fed-tax').textContent = fmt(fedTax);
  document.getElementById('state-tax').textContent = fmt(stateTax);
  document.getElementById('ss').textContent = fmt(ss);
  document.getElementById('medicare').textContent = fmt(medicare);
  document.getElementById('net-annual').textContent = fmt(netAnnual);
  document.getElementById('net-paycheck').textContent = fmt(netAnnual / freq);
  document.getElementById('effective-rate').textContent = effectiveRate.toFixed(1) + '%';
  document.getElementById('marginal-rate').textContent = (marginalRate * 100).toFixed(0) + '%';
  document.getElementById('results').classList.add('show');
}
document.addEventListener('keydown', e => { if (e.key === 'Enter') calculate(); });
</script>
