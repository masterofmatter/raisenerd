---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="RaiseNerd — Free Salary & HR Calculators"
  description="Free pay raise, overtime, salary to hourly, paycheck, and cost of living calculators. Know your worth. No signup required."
>
  <div class="card">
    <h1>Free Salary & HR Calculators</h1>
    <p>Know your numbers before your next negotiation. Fast, accurate tools — no signup, no fluff.</p>
  </div>

  <div class="tools-grid">
    <a href="/pay-raise-calculator/" class="tool-card">
      <div class="tool-icon">📈</div>
      <div>
        <h2>Pay Raise Calculator</h2>
        <p>Calculate the dollar amount and percentage of any raise. See your new annual and monthly salary instantly.</p>
        <span class="tag">Most popular</span>
      </div>
    </a>
    <a href="/overtime-calculator/" class="tool-card">
      <div class="tool-icon">⏱️</div>
      <div>
        <h2>Overtime Calculator</h2>
        <p>Calculate time-and-a-half, double time, and total pay for any number of overtime hours.</p>
      </div>
    </a>
    <a href="/salary-to-hourly-calculator/" class="tool-card">
      <div class="tool-icon">🔄</div>
      <div>
        <h2>Salary to Hourly Calculator</h2>
        <p>Convert annual salary to hourly rate — or hourly wage to annual, monthly, and biweekly pay.</p>
      </div>
    </a>
    <a href="/paycheck-calculator/" class="tool-card">
      <div class="tool-icon">💵</div>
      <div>
        <h2>Paycheck Calculator</h2>
        <p>Estimate your take-home pay after federal and state taxes. Supports salary and hourly workers.</p>
      </div>
    </a>
    <a href="/cost-of-living-calculator/" class="tool-card">
      <div class="tool-icon">🏙️</div>
      <div>
        <h2>Cost of Living Calculator</h2>
        <p>Find out what salary you need in a new city to maintain your current standard of living.</p>
        <span class="tag tag-green">New</span>
      </div>
    </a>
  </div>
</Layout>

<style>
  .tools-grid { display: flex; flex-direction: column; gap: 1rem; }
  .tool-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: var(--text);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .tool-card:hover {
    border-color: var(--green);
    box-shadow: 0 2px 12px rgba(5,150,105,0.1);
    text-decoration: none;
  }
  .tool-icon { font-size: 2rem; flex-shrink: 0; line-height: 1; margin-top: 0.1rem; }
  .tool-card h2 { font-size: 1.05rem; color: var(--indigo); margin-bottom: 0.25rem; }
  .tool-card p { font-size: 0.88rem; color: var(--muted); margin: 0; }
  .tag {
    display: inline-block;
    margin-top: 0.4rem;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: #ede9fe;
    color: var(--indigo-mid);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .tag-green { background: #d1fae5; color: var(--green); }
</style>
