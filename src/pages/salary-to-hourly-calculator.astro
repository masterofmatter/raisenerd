---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Salary to Hourly Calculator — Free | RaiseNerd"
  description="Convert annual salary to hourly rate instantly. Or calculate annual salary from hourly wage. See monthly, biweekly, weekly, and daily pay. Free."
>
  <div class="card">
    <h1>Salary to Hourly Calculator</h1>
    <p>Convert between annual salary and hourly wage. See every pay period — hourly, daily, weekly, biweekly, monthly, and annual.</p>
  </div>

  <div class="ad-slot ad-slot-banner">Ad</div>

  <div class="card">
    <div class="mode-tabs">
      <button class="tab active" onclick="setMode('salary')">Annual Salary → Hourly</button>
      <button class="tab" onclick="setMode('hourly')">Hourly → Annual Salary</button>
    </div>

    <div id="mode-salary" class="calc-form" style="margin-top:1.25rem;">
      <div class="field-row">
        <div class="field">
          <label for="annual">Annual Salary ($)</label>
          <input type="number" id="annual" placeholder="e.g. 65000" min="0" step="100" />
        </div>
        <div class="field">
          <label for="hours-week">Hours per Week</label>
          <input type="number" id="hours-week" placeholder="e.g. 40" min="1" max="80" step="0.5" value="40" />
        </div>
      </div>
      <div class="field">
        <label for="weeks-year">Weeks Worked per Year</label>
        <select id="weeks-year">
          <option value="52">52 weeks (no unpaid time off)</option>
          <option value="50">50 weeks (2 weeks unpaid)</option>
          <option value="48">48 weeks (4 weeks unpaid)</option>
        </select>
      </div>
      <button class="btn" onclick="calcFromSalary()">Convert to Hourly</button>
    </div>

    <div id="mode-hourly" class="calc-form" style="margin-top:1.25rem;display:none;">
      <div class="field-row">
        <div class="field">
          <label for="hourly-in">Hourly Rate ($)</label>
          <input type="number" id="hourly-in" placeholder="e.g. 25.00" min="0" step="0.01" />
        </div>
        <div class="field">
          <label for="hours-week2">Hours per Week</label>
          <input type="number" id="hours-week2" placeholder="e.g. 40" min="1" max="80" step="0.5" value="40" />
        </div>
      </div>
      <button class="btn" onclick="calcFromHourly()">Convert to Salary</button>
    </div>

    <div class="results" id="results">
      <strong style="color:var(--indigo);">Pay Breakdown</strong>
      <div class="results-grid" style="margin-top:0.75rem;">
        <div class="result-item result-highlight">
          <span class="result-value" id="res-hourly">—</span>
          <span class="result-label">Hourly</span>
        </div>
        <div class="result-item">
          <span class="result-value" id="res-daily">—</span>
          <span class="result-label">Daily (8 hrs)</span>
        </div>
        <div class="result-item">
          <span class="result-value" id="res-weekly">—</span>
          <span class="result-label">Weekly</span>
        </div>
        <div class="result-item">
          <span class="result-value" id="res-biweekly">—</span>
          <span class="result-label">Biweekly</span>
        </div>
        <div class="result-item">
          <span class="result-value" id="res-monthly">—</span>
          <span class="result-label">Monthly</span>
        </div>
        <div class="result-item result-highlight">
          <span class="result-value" id="res-annual">—</span>
          <span class="result-label">Annual</span>
        </div>
      </div>
    </div>
  </div>

  <div class="ad-slot ad-slot-banner">Ad</div>

  <div class="card">
    <h2>Salary to Hourly Formula</h2>
    <div class="formula-box">
      <p><strong>Hourly Rate</strong> = Annual Salary ÷ (Hours per Week × Weeks per Year)</p>
      <p><strong>Annual Salary</strong> = Hourly Rate × Hours per Week × Weeks per Year</p>
    </div>
    <p style="margin-top:0.85rem;">The standard assumption is 40 hours/week × 52 weeks = 2,080 hours/year. If you take unpaid time off, use a lower weeks figure to get a more accurate hourly rate.</p>

    <h2 style="margin-top:1.5rem;">Common Salary to Hourly Reference</h2>
    <table class="bench-table">
      <thead><tr><th>Annual Salary</th><th>Hourly (40 hrs)</th><th>Monthly</th></tr></thead>
      <tbody>
        <tr><td>$40,000</td><td>$19.23</td><td>$3,333</td></tr>
        <tr><td>$50,000</td><td>$24.04</td><td>$4,167</td></tr>
        <tr><td>$60,000</td><td>$28.85</td><td>$5,000</td></tr>
        <tr><td>$75,000</td><td>$36.06</td><td>$6,250</td></tr>
        <tr><td>$100,000</td><td>$48.08</td><td>$8,333</td></tr>
        <tr><td>$120,000</td><td>$57.69</td><td>$10,000</td></tr>
        <tr><td>$150,000</td><td>$72.12</td><td>$12,500</td></tr>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2>Frequently Asked Questions</h2>
    <details>
      <summary>How many work hours are in a year?</summary>
      <p>The standard is 2,080 hours (40 hours/week × 52 weeks). If you account for 10 vacation days and 10 stat holidays, it drops to about 1,880 paid hours. For a more accurate picture of your effective hourly rate, use the weeks worked input above.</p>
    </details>
    <details>
      <summary>Is a $25/hour job a good salary in Canada?</summary>
      <p>At $25/hour working 40 hours/week, you earn $52,000/year — around the median individual income in Canada. In lower cost-of-living cities this is comfortable; in Toronto or Vancouver, it covers basics but leaves little room for saving. Use our <a href="/cost-of-living-calculator/">Cost of Living Calculator</a> to compare cities.</p>
    </details>
    <details>
      <summary>How do I convert a daily rate to annual salary?</summary>
      <p>Daily rate × working days per year. Assuming 260 working days (52 weeks × 5 days): a $300/day contract = $78,000/year equivalent. However, contractors typically don't receive benefits, paid vacation, or employer CPP/EI contributions — so the true comparison to an employee salary is lower.</p>
    </details>
  </div>
</Layout>

<style>
  .mode-tabs { display: flex; gap: 0.5rem; border-bottom: 2px solid var(--border); }
  .tab { background: none; border: none; padding: 0.6rem 1rem; font-size: 0.88rem; cursor: pointer; color: var(--muted); border-bottom: 2px solid transparent; margin-bottom: -2px; font-weight: 500; }
  .tab.active { color: var(--green); border-bottom-color: var(--green); font-weight: 600; }
</style>

<script is:inline>
function setMode(mode) {
  document.getElementById('mode-salary').style.display = mode === 'salary' ? 'flex' : 'none';
  document.getElementById('mode-hourly').style.display = mode === 'hourly' ? 'flex' : 'none';
  document.querySelectorAll('.tab').forEach((t, i) => t.classList.toggle('active', (mode === 'salary') === (i === 0)));
  document.getElementById('results').classList.remove('show');
}
function fmt(n, d = 2) {
  return '$' + n.toLocaleString('en-CA', { minimumFractionDigits: d, maximumFractionDigits: d });
}
function show(hourlyRate, hoursPerWeek) {
  document.getElementById('res-hourly').textContent = fmt(hourlyRate);
  document.getElementById('res-daily').textContent = fmt(hourlyRate * 8);
  document.getElementById('res-weekly').textContent = fmt(hourlyRate * hoursPerWeek);
  document.getElementById('res-biweekly').textContent = fmt(hourlyRate * hoursPerWeek * 2);
  document.getElementById('res-monthly').textContent = fmt(hourlyRate * hoursPerWeek * 52 / 12);
  document.getElementById('res-annual').textContent = fmt(hourlyRate * hoursPerWeek * 52, 0);
  document.getElementById('results').classList.add('show');
}
function calcFromSalary() {
  const annual = parseFloat(document.getElementById('annual').value) || 0;
  const hrs = parseFloat(document.getElementById('hours-week').value) || 40;
  const wks = parseFloat(document.getElementById('weeks-year').value) || 52;
  if (annual <= 0) { alert('Please enter your annual salary.'); return; }
  show(annual / (hrs * wks), hrs);
}
function calcFromHourly() {
  const rate = parseFloat(document.getElementById('hourly-in').value) || 0;
  const hrs = parseFloat(document.getElementById('hours-week2').value) || 40;
  if (rate <= 0) { alert('Please enter your hourly rate.'); return; }
  show(rate, hrs);
}
document.addEventListener('keydown', e => { if (e.key === 'Enter') { document.getElementById('mode-salary').style.display !== 'none' ? calcFromSalary() : calcFromHourly(); }});
</script>
